# The Atelier — Environment Configuration
# Copy to .env if needed (config is managed via /setup wizard and stored in data/config.json)

# Server bind settings
# APP_HOST=127.0.0.1
# APP_PORT=8000

# Optional: default local endpoint on first launch
# LOCAL_ENDPOINT_URL=http://localhost:5000/v1

# Optional: SearXNG base URL for web search toggle
# SEARXNG_INSTANCE=http://localhost:8080
